# ── Loan Pool Advisor Backend Environment ──────────────────────────
# Copy this file to .env and fill in your keys.
# The .env file is git-ignored and should NEVER be committed.

# Groq API Key (primary AI provider)
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# Claude/Anthropic API Key (optional, paid)
# ANTHROPIC_API_KEY=

# Server port
PORT=3001

# Node environment
NODE_ENV=development
