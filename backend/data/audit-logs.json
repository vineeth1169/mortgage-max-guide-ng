      "action": "rule.updated",
      "ruleId": "RATE-001",
      "ruleName": "Interest Rate Range",
      "userId": "system",
      "previousVersion": "1.0.0",
      "newVersion": "1.0.1",
      "changes": {
        "before": {
          "id": "RATE-001",
          "name": "Interest Rate Range",
          "category": "rate",
          "description": "The note rate must be greater than 0% and not exceed 12%",
          "requirement": "0% < interestRate ≤ 12%",
          "field": "interestRate",
          "operator": "range",
          "minValue": 0.001,
          "maxValue": 15,
          "minInclusive": false,
          "maxInclusive": true,
          "severity": "error",
          "guideReference": "Section 4301.1",
          "explanation": "Interest rates must be positive and within reasonable market bounds. Loans with 0% or negative rates are typically special programs not eligible for standard pool delivery. Rates exceeding 12% may indicate high-cost loans requiring special handling.",
          "remediation": "Verify the interest rate is correctly entered. If the rate is outside normal bounds, check if this loan qualifies for a special program.",
          "enabled": true,
